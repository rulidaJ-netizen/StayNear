# Local development only.
# Do not commit real credentials here.

# Preferred Prisma/Supabase connection for auth and migrated routes.
DATABASE_URL="postgresql://postgres:password@db.example.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:password@db.example.supabase.co:5432/postgres"

# Optional legacy MySQL connection for routes that still use mysql2 directly.
# Leave this unset if you are only working on the Prisma/Supabase-backed auth flow.
# MYSQL_DATABASE_URL="mysql://root:password@127.0.0.1:3306/staynear_db"

JWT_SECRET=replace_with_a_long_random_secret
NODE_ENV=development
PORT=5000

DATA_DIR=
UPLOADS_DIR=
STORAGE_DIR=
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Local Vite development uses the proxy in vite.config.js.
# Prefer placing these Vite-only variables in .env.development locally
# so the backend can keep using .env without mixing frontend build values.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:5000
VITE_API_URL=/api
VITE_IMAGE_BASE_URL=http://localhost:5000
