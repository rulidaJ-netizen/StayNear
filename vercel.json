{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/landowner/boarding-houses/:id/photos",
      "destination": "https://staynear-api-production.up.railway.app/api/landowner/boarding-houses/:id/photos"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/proxy?path=:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://staynear-api-production.up.railway.app/uploads/:path*"
    },
    {
      "source": "/((?!api/|uploads/).*)",
      "destination": "/index.html"
    }
  ]
}
